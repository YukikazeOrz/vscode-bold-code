-			this.logService.trace('[aiHub] failed to read Sub2API session', error);
-			if (!this.gatewayBrowserVisible && this.activeDrawer === 'gateway') {
-				this.renderGatewayLogin(gatewayUrl, localize('aiHub.gatewayConnectionFailed', "无法连接 AI Gateway。"));
-			}
