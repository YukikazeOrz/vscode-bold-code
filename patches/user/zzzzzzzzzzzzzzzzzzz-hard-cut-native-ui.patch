-			const result = parseSub2ApiScriptResult(await model.executeJavaScript(SUB2API_SESSION_SCRIPT));
-			if (!result || this.activeDrawer !== 'gateway') {
-				return;
-			}
-
-			switch (result.status) {
-				case 'authenticated':
-					if (result.apiKey) {
-						await this.saveImportedGatewayApiKey({ apiKey: result.apiKey, baseUrl: inferGatewayApiBaseUrl(gatewayUrl) });
-					}
-					break;
-				case 'noKey':
-					if (!this.gatewayBrowserVisible) {
-						this.renderGatewayNoKey(gatewayUrl);
-					}
-					break;
-				case 'signedOut':
-					if (!this.gatewayBrowserVisible) {
-						this.renderGatewayLogin(gatewayUrl);
-					}
-					break;
-				case 'error':
-					if (!this.gatewayBrowserVisible) {
