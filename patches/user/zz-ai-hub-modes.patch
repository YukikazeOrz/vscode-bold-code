+}
+
+function readLayoutSnapshot(storageService: IStorageService): IAiHubLayoutSnapshot | undefined {
+	const raw = storageService.get(AI_HUB_LAYOUT_STORAGE_KEY, StorageScope.PROFILE);
+	if (!raw) {
+		return undefined;
+	}
+
+	try {
+		return JSON.parse(raw) as IAiHubLayoutSnapshot;
+	} catch {
+		return undefined;
+	}
+}
+
+async function openFirstAvailableViewContainer(viewsService: IViewsService, containerIds: readonly string[]): Promise<void> {
+	for (const id of containerIds) {
+		try {
+			const paneComposite = await viewsService.openViewContainer(id, true);
+			if (paneComposite) {
+				return;
+			}
+		} catch {
+			// Some agent containers are conditional; try the next known container.
+		}
+	}
+}
+
+async function restoreEditLayout(storageService: IStorageService, layoutService: IWorkbenchLayoutService, viewsService: IViewsService): Promise<void> {
+	layoutService.setAuxiliaryBarMaximized(false);
+	const snapshot = readLayoutSnapshot(storageService);
+	if (!snapshot) {
+		layoutService.setPartHidden(false, Parts.ACTIVITYBAR_PART);
+		layoutService.setPartHidden(false, Parts.EDITOR_PART);
+		layoutService.setPartHidden(true, Parts.PANEL_PART);
+		return;
+	}
+
+	layoutService.setPartHidden(!snapshot.activityBarVisible, Parts.ACTIVITYBAR_PART);
+	layoutService.setPartHidden(!snapshot.editorVisible, Parts.EDITOR_PART);
+	layoutService.setPartHidden(!snapshot.panelVisible, Parts.PANEL_PART);
+
+	if (snapshot.sideBarVisible) {
+		layoutService.setPartHidden(false, Parts.SIDEBAR_PART);
+		if (snapshot.sideBarContainerId) {
+			await viewsService.openViewContainer(snapshot.sideBarContainerId, false);
+		}
+	} else {
+		layoutService.setPartHidden(true, Parts.SIDEBAR_PART);
+	}
+
+	if (snapshot.auxiliaryBarVisible) {
+		layoutService.setPartHidden(false, Parts.AUXILIARYBAR_PART);
+		if (snapshot.auxiliaryBarContainerId) {
+			await viewsService.openViewContainer(snapshot.auxiliaryBarContainerId, false);
+		}
+	} else {
+		layoutService.setPartHidden(true, Parts.AUXILIARYBAR_PART);
+	}
+
+	storageService.remove(AI_HUB_LAYOUT_STORAGE_KEY, StorageScope.PROFILE);
+}
+
+async function applyAgentLayout(mode: AiHubMode, commandService: ICommandService, layoutService: IWorkbenchLayoutService, viewsService: IViewsService, logService: ILogService): Promise<void> {
+	layoutService.setAuxiliaryBarMaximized(false);
+	layoutService.setPartHidden(false, Parts.SIDEBAR_PART);
+	layoutService.setPartHidden(false, Parts.AUXILIARYBAR_PART);
+	layoutService.setPartHidden(true, Parts.ACTIVITYBAR_PART);
+	layoutService.setPartHidden(true, Parts.PANEL_PART);
+	layoutService.setPartHidden(true, Parts.EDITOR_PART);
+
+	try {
+		await commandService.executeCommand(mode === 'claudeAgent' ? 'claude-vscode.sidebar.open' : 'chatgpt.openSidebar');
+	} catch (err) {
+		logService.warn('[aiHub] failed to open agent sidebar via extension command', err);
+	}
+
+	await openFirstAvailableViewContainer(viewsService, getAgentContainerIds(mode));
+
+	const sideBarContainerId = viewsService.getVisibleViewContainer(ViewContainerLocation.Sidebar)?.id;
+	const auxiliaryBarContainerId = viewsService.getVisibleViewContainer(ViewContainerLocation.AuxiliaryBar)?.id;
+	const agentContainerIds = new Set(getAgentContainerIds(mode));
+
+	if (sideBarContainerId && agentContainerIds.has(sideBarContainerId)) {
+		layoutService.setPartHidden(false, Parts.SIDEBAR_PART);
+		layoutService.setPartHidden(true, Parts.AUXILIARYBAR_PART);
+	} else if (auxiliaryBarContainerId && agentContainerIds.has(auxiliaryBarContainerId)) {
+		layoutService.setPartHidden(false, Parts.AUXILIARYBAR_PART);
+		layoutService.setPartHidden(true, Parts.SIDEBAR_PART);
+		layoutService.setAuxiliaryBarMaximized(true);
+	} else {
+		layoutService.setPartHidden(false, Parts.AUXILIARYBAR_PART);
+		layoutService.setPartHidden(true, Parts.SIDEBAR_PART);
+		layoutService.setAuxiliaryBarMaximized(true);
+	}
+
+	layoutService.setPartHidden(true, Parts.EDITOR_PART);
+	layoutService.setPartHidden(true, Parts.PANEL_PART);
+	layoutService.setPartHidden(true, Parts.ACTIVITYBAR_PART);
+	layoutService.layout();
+}
+
+async function applyAiHubMode(mode: AiHubMode, previousMode: AiHubMode, storageService: IStorageService, commandService: ICommandService, layoutService: IWorkbenchLayoutService, viewsService: IViewsService, logService: ILogService): Promise<void> {
+	if (mode === 'edit') {
+		if (previousMode !== 'edit' || readLayoutSnapshot(storageService)) {
+			await restoreEditLayout(storageService, layoutService, viewsService);
+		}
+		return;
+	}
