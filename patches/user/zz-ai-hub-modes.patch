+}
+
+function captureEditLayout(layoutService: IWorkbenchLayoutService, viewsService: IViewsService): IAiHubLayoutSnapshot {
+	return {
+		activityBarVisible: layoutService.isVisible(Parts.ACTIVITYBAR_PART),
+		sideBarVisible: layoutService.isVisible(Parts.SIDEBAR_PART),
+		sideBarContainerId: viewsService.getVisibleViewContainer(ViewContainerLocation.Sidebar)?.id,
+		auxiliaryBarVisible: layoutService.isVisible(Parts.AUXILIARYBAR_PART),
+		auxiliaryBarContainerId: viewsService.getVisibleViewContainer(ViewContainerLocation.AuxiliaryBar)?.id,
+		panelVisible: layoutService.isVisible(Parts.PANEL_PART),
+		editorVisible: layoutService.isVisible(Parts.EDITOR_PART, mainWindow),
