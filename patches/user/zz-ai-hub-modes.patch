+	if (previousMode === 'edit' && !readLayoutSnapshot(storageService)) {
+		storageService.store(AI_HUB_LAYOUT_STORAGE_KEY, JSON.stringify(captureEditLayout(layoutService, viewsService)), StorageScope.PROFILE, StorageTarget.USER);
+	}
+
+	await applyAgentLayout(mode, commandService, layoutService, viewsService, logService);
+}
