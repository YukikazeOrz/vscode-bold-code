+	grid-template-columns: minmax(0, 1fr) auto;
+	gap: 6px;
+}
+
+.bold-frontend__native-search-input,
+.bold-frontend__native-ssh-input {
+	height: 34px;
+	box-sizing: border-box;
+	border: 1px solid color-mix(in srgb, var(--vscode-foreground) 10%, transparent);
+	border-radius: 9px;
+	outline: 0;
+	background:
+		linear-gradient(135deg, color-mix(in srgb, var(--vscode-focusBorder) 7%, transparent), transparent 58%),
+		color-mix(in srgb, var(--vscode-input-background) 94%, #080b12);
+	color: var(--vscode-input-foreground);
+	font: inherit;
+	font-size: 12px;
+}
+
+.bold-frontend__native-search-input {
+	padding: 0 11px;
+}
+
+.bold-frontend__native-ssh-input {
+	padding: 0 10px;
+}
+
+.bold-frontend__native-search-input:focus,
+.bold-frontend__native-ssh-input:focus {
+	border-color: color-mix(in srgb, var(--vscode-focusBorder) 68%, transparent);
+	box-shadow: 0 0 0 2px color-mix(in srgb, var(--vscode-focusBorder) 14%, transparent);
+}
+
+.bold-frontend__native-search-submit,
+.bold-frontend__native-ssh-submit,
+.bold-frontend__native-ssh-secondary {
+	min-height: 34px;
+	border: 1px solid color-mix(in srgb, var(--vscode-focusBorder) 28%, transparent);
+	border-radius: 9px;
+	background: color-mix(in srgb, var(--vscode-focusBorder) 14%, var(--vscode-input-background));
+	color: var(--vscode-foreground);
+	cursor: pointer;
+	font: inherit;
+	font-size: 11px;
+}
+
+.bold-frontend__native-search-submit {
+	width: 38px;
+}
+
+.bold-frontend__native-ssh-submit {
+	padding: 0 10px;
+}
+
+.bold-frontend__native-search-summary,
+.bold-frontend__native-ssh-status {
+	padding: 10px 2px 8px;
+	color: var(--vscode-descriptionForeground);
+	font-size: 10px;
+	line-height: 1.5;
+}
+
+.bold-frontend__native-search-results,
+.bold-frontend__native-ssh-hosts {
+	display: grid;
+	gap: 7px;
+}
+
+.bold-frontend__native-search-result,
+.bold-frontend__native-ssh-host {
+	border: 1px solid color-mix(in srgb, var(--vscode-foreground) 7%, transparent);
+	border-radius: 9px;
+	background: color-mix(in srgb, var(--vscode-editor-background) 72%, transparent);
+}
+
+.bold-frontend__native-search-file,
+.bold-frontend__native-search-match,
+.bold-frontend__native-ssh-host {
+	width: 100%;
+	box-sizing: border-box;
+	border: 0;
+	background: transparent;
+	color: inherit;
+	cursor: pointer;
+	font: inherit;
+	text-align: left;
+}
+
+.bold-frontend__native-search-file,
+.bold-frontend__native-ssh-host {
+	display: grid;
+	gap: 3px;
+	padding: 9px 10px;
+}
+
+.bold-frontend__native-search-file strong,
+.bold-frontend__native-ssh-host strong {
+	overflow: hidden;
+	font-size: 12px;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.bold-frontend__native-search-file span,
+.bold-frontend__native-ssh-host span {
+	overflow: hidden;
+	color: var(--vscode-descriptionForeground);
+	font-size: 10px;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.bold-frontend__native-search-match {
+	display: grid;
+	grid-template-columns: 34px minmax(0, 1fr);
+	gap: 8px;
+	padding: 6px 10px 8px;
+	border-top: 1px solid color-mix(in srgb, var(--vscode-foreground) 6%, transparent);
+}
+
+.bold-frontend__native-search-line {
+	color: color-mix(in srgb, var(--vscode-focusBorder) 70%, var(--vscode-descriptionForeground));
+	font-family: var(--vscode-editor-font-family);
+	font-size: 10px;
+	text-align: right;
+}
+
+.bold-frontend__native-search-preview {
+	overflow: hidden;
+	color: color-mix(in srgb, var(--vscode-foreground) 75%, transparent);
+	font-family: var(--vscode-editor-font-family);
+	font-size: 10px;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.bold-frontend__native-search-file:hover,
+.bold-frontend__native-search-match:hover,
+.bold-frontend__native-ssh-host:hover {
+	background: color-mix(in srgb, var(--vscode-focusBorder) 10%, transparent);
+}
+
+.bold-frontend__native-ssh-actions {
+	display: flex;
+	margin-top: 10px;
+}
+
+.bold-frontend__native-ssh-secondary {
+	width: 100%;
+	background: color-mix(in srgb, var(--vscode-input-background) 92%, transparent);
+	color: color-mix(in srgb, var(--vscode-foreground) 78%, transparent);
+}
+
+.bold-frontend__native-ssh.is-connecting .bold-frontend__native-ssh-status::before {
+	display: inline-block;
+	width: 9px;
+	height: 9px;
+	margin-right: 7px;
+	border: 2px solid color-mix(in srgb, var(--vscode-focusBorder) 24%, transparent);
+	border-top-color: var(--vscode-focusBorder);
+	border-radius: 99px;
+	vertical-align: -1px;
+	animation: bold-gateway-spin 800ms linear infinite;
+	content: '';
+}
