+	private async pickSSHHost(): Promise<void> {
+		const hosts = await this.readSSHConfigHosts();
+		const picks: ISSHHostPick[] = hosts.map(host => ({
+			label: `$(remote) ${host.alias}`,
+			description: host.destination,
+			detail: host.detail,
+			hostAlias: host.alias,
+		}));
