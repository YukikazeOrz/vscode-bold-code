+function appendGatewayImportParameters(gatewayUrl: string): string {
+	try {
+		const url = new URL(gatewayUrl);
+		url.searchParams.set('ai_hub_import', '1');
+		url.searchParams.set('vscode_import_callback', AI_GATEWAY_IMPORT_CALLBACK_URL);
+		url.searchParams.set('import_callback', AI_GATEWAY_IMPORT_CALLBACK_URL);
+		return url.toString();
+	} catch {
+		return gatewayUrl;
+	}
+}
+
+function getHashParams(url: URL): URLSearchParams {
+	const hash = url.hash.replace(/^#/, '');
+	if (!hash) {
+		return new URLSearchParams();
+	}
+
+	const queryStart = hash.indexOf('?');
+	return new URLSearchParams(queryStart >= 0 ? hash.slice(queryStart + 1) : hash);
+}
+
+function getFirstParam(searchParams: readonly URLSearchParams[], names: readonly string[]): string | undefined {
+	for (const params of searchParams) {
+		for (const name of names) {
+			const value = params.get(name)?.trim();
+			if (value) {
+				return value;
+			}
+		}
+	}
+	return undefined;
+}
+
+function inferGatewayApiBaseUrl(gatewayUrl: string): string {
+	try {
+		return new URL('/v1', gatewayUrl).toString().replace(/\/$/, '');
+	} catch {
+		return '';
+	}
+}
+
+function parseGatewayImportedKey(navigatedUrl: string, gatewayUrl: string): { apiKey: string; baseUrl: string } | undefined {
+	let url: URL;
+	try {
+		url = new URL(navigatedUrl);
+	} catch {
+		return undefined;
+	}
+
+	const params = [url.searchParams, getHashParams(url)];
+	const importRoute = `${url.host}${url.pathname}`.toLowerCase().includes('ai-gateway/import')
+		|| url.searchParams.get('ai_hub_import') === '1'
+		|| url.searchParams.get('import_api_key') === '1';
+	const apiKey = getFirstParam(params, API_KEY_PARAM_NAMES)
+		?? (importRoute ? getFirstParam(params, IMPORT_ONLY_KEY_PARAM_NAMES) : undefined);
+	if (!apiKey || apiKey.length < 8) {
+		return undefined;
+	}
+
+	return {
+		apiKey,
+		baseUrl: getFirstParam(params, BASE_URL_PARAM_NAMES) ?? inferGatewayApiBaseUrl(gatewayUrl),
+	};
+}
