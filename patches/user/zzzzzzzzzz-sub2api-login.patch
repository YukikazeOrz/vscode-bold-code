+	private async loginSub2Api(gatewayUrl: string, email: string, password: string): Promise<void> {
+		const model = this.gatewayModel;
+		if (!model || !hasSameOrigin(model.url, gatewayUrl)) {
+			this.renderGatewayLogin(gatewayUrl, localize('aiHub.gatewayLoginPageUnavailable', "AI Gateway 登录页尚未准备好，请稍后重试。"));
+			return;
+		}
+		this.renderGatewayLoading(localize('aiHub.gatewayLoggingIn', "正在登录..."));
+		try {
+			const result = parseSub2ApiScriptResult(await model.executeJavaScript(buildSub2ApiLoginScript(email, password)));
+			if (this.activeDrawer !== 'gateway') {
+				return;
+			}
+			if (result?.status === 'twoFactor' && result.tempToken) {
+				this.renderGatewayTwoFactor(gatewayUrl, result.tempToken, result.userEmailMasked);
+				return;
+			}
+			if (result?.status === 'authenticated') {
+				this.gatewayApiKeyImported = false;
+				await this.refreshSub2ApiSession(model, gatewayUrl);
+				return;
+			}
+			this.renderGatewayLogin(gatewayUrl, result?.message ?? localize('aiHub.gatewayLoginFailed', "登录失败，请检查账号和密码。"));
+		} catch (error) {
+			this.logService.warn('[aiHub] Sub2API login failed', error);
+			if (this.activeDrawer === 'gateway') {
+				this.renderGatewayLogin(gatewayUrl, localize('aiHub.gatewayLoginFailed', "登录失败，请检查账号和密码。"));
+			}
+		}
+	}
+
