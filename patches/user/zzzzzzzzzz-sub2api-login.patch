+function parseSub2ApiScriptResult(value: unknown): ISub2ApiScriptResult | undefined {
+	if (!value || typeof value !== 'object') {
+		return undefined;
+	}
+	const candidate = value as Record<string, unknown>;
+	if (candidate.status !== 'authenticated' && candidate.status !== 'noKey' && candidate.status !== 'signedOut' && candidate.status !== 'twoFactor' && candidate.status !== 'error') {
+		return undefined;
+	}
+	return {
+		status: candidate.status,
+		apiKey: typeof candidate.apiKey === 'string' && candidate.apiKey.trim().length >= 8 ? candidate.apiKey.trim() : undefined,
+		message: typeof candidate.message === 'string' ? candidate.message : undefined,
+		tempToken: typeof candidate.tempToken === 'string' ? candidate.tempToken : undefined,
+		userEmailMasked: typeof candidate.userEmailMasked === 'string' ? candidate.userEmailMasked : undefined,
+	};
