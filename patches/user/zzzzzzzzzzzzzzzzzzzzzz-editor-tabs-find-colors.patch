+/* The Bold editor sits outside the native workbench, so it must inherit these
+ * visual tokens explicitly instead of relying on the hidden workbench root. */
+.bold-frontend__editor .monaco-editor .focused .selected-text,
+.bold-frontend__editor .monaco-editor.focused .selected-text {
+	background-color: var(--vscode-editor-selectionBackground) !important;
+}
+
+.bold-frontend__editor .monaco-editor .selected-text {
+	background-color: var(--vscode-editor-inactiveSelectionBackground) !important;
+}
+
+.bold-frontend__editor .monaco-editor .currentFindMatch,
+.bold-frontend__editor .monaco-editor .findMatch {
+	background-color: var(--vscode-editor-findMatchBackground) !important;
+}
+
+.bold-frontend__editor .monaco-editor .findMatchHighlight {
+	background-color: var(--vscode-editor-findMatchHighlightBackground) !important;
+}
+
 .bold-frontend__editor[hidden] {
