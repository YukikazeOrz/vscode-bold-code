@@ -0,0 +1,291 @@
+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { RunOnceScheduler } from '../../../../base/common/async.js';
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { mainWindow } from '../../../../base/browser/window.js';
+import { ICommandService } from '../../../../platform/commands/common/commands.js';
+import { ILogService } from '../../../../platform/log/common/log.js';
+import { IStorageService, StorageScope, StorageTarget } from '../../../../platform/storage/common/storage.js';
+import { ViewContainerLocation } from '../../../common/views.js';
+import { IWorkbenchLayoutService, Parts } from '../../../services/layout/browser/layoutService.js';
+import { IViewsService } from '../../../services/views/common/viewsService.js';
+import { AiHubMode, IAiConfigService, IAiHubModeController } from './aiHubTypes.js';
+
+const AI_HUB_LAYOUT_STORAGE_KEY = 'aiHub.editModeLayout';
+const CLAUDE_AGENT_CONTAINER_IDS = ['claude-sidebar', 'claude-sidebar-secondary'];
+const CODEX_AGENT_CONTAINER_IDS = ['codexViewContainer', 'codexSecondaryViewContainer'];
+
+interface IAiHubLayoutSnapshot {
+	readonly activityBarVisible: boolean;
+	readonly sideBarVisible: boolean;
+	readonly sideBarContainerId?: string;
+	readonly auxiliaryBarVisible: boolean;
+	readonly auxiliaryBarContainerId?: string;
+	readonly panelVisible: boolean;
+	readonly editorVisible: boolean;
+}
+
+export class AiHubModeController extends Disposable implements IAiHubModeController {
+
+	declare readonly _serviceBrand: undefined;
+
+	private currentMode: AiHubMode = 'edit';
+	private initialization: Promise<void> | undefined;
+	private applyingLayout = false;
+	private readonly enforcementScheduler = this._register(new RunOnceScheduler(() => void this.enforceAgentLayout(), 0));
+
+	constructor(
+		@IAiConfigService private readonly aiConfigService: IAiConfigService,
+		@IStorageService private readonly storageService: IStorageService,
+		@ICommandService private readonly commandService: ICommandService,
+		@IWorkbenchLayoutService private readonly layoutService: IWorkbenchLayoutService,
+		@IViewsService private readonly viewsService: IViewsService,
+		@ILogService private readonly logService: ILogService,
+	) {
+		super();
+
+		this._register(this.layoutService.onDidChangePartVisibility(event => {
+			if (this.currentMode !== 'edit' && event.visible && this.isForbiddenPart(event.partId)) {
+				this.enforcementScheduler.schedule();
+			}
+		}));
+		this._register(this.layoutService.onDidChangeAuxiliaryBarMaximized(() => {
+			if (this.currentMode !== 'edit') {
+				this.enforcementScheduler.schedule();
+			}
+		}));
+		this._register(this.viewsService.onDidChangeViewContainerVisibility(event => {
+			if (this.currentMode !== 'edit' && event.visible && !this.getAgentContainerIds(this.currentMode).includes(event.id)) {
+				this.enforcementScheduler.schedule();
+			}
+		}));
+	}
+
+	get mode(): AiHubMode {
+		return this.currentMode;
+	}
+
+	initialize(): Promise<void> {
+		if (!this.initialization) {
+			this.initialization = this.doInitialize();
+		}
+		return this.initialization;
+	}
+
+	private async doInitialize(): Promise<void> {
+		const state = await this.aiConfigService.getState();
+		this.currentMode = state.mode;
+		await this.applyModeLayout(state.mode, state.mode);
+		if (state.mode !== 'edit') {
+			this.enforcementScheduler.schedule();
+		}
+	}
+
+	async setMode(mode: AiHubMode): Promise<void> {
+		await this.initialize();
+		const previousMode = this.currentMode;
+		if (mode === previousMode) {
+			this.enforcementScheduler.schedule();
+			return;
+		}
+
+		if (previousMode === 'edit' && mode !== 'edit' && !this.readLayoutSnapshot()) {
+			this.storageService.store(AI_HUB_LAYOUT_STORAGE_KEY, JSON.stringify(this.captureEditLayout()), StorageScope.PROFILE, StorageTarget.USER);
+		}
+
+		this.currentMode = mode;
+		this.applyingLayout = true;
+		try {
+			await this.aiConfigService.setMode(mode);
+			await this.applyModeLayout(mode, previousMode);
+		} catch (error) {
+			this.currentMode = previousMode;
+			this.applyingLayout = false;
+			throw error;
+		}
+
+		if (mode !== 'edit') {
+			this.enforcementScheduler.schedule();
+		}
+	}
+
+	private getAgentContainerIds(mode: AiHubMode): readonly string[] {
+		if (mode === 'claudeAgent') {
+			return CLAUDE_AGENT_CONTAINER_IDS;
+		}
+		if (mode === 'codexAgent') {
+			return CODEX_AGENT_CONTAINER_IDS;
+		}
+		return [];
+	}
+
+	private captureEditLayout(): IAiHubLayoutSnapshot {
+		return {
+			activityBarVisible: this.layoutService.isVisible(Parts.ACTIVITYBAR_PART),
+			sideBarVisible: this.layoutService.isVisible(Parts.SIDEBAR_PART),
+			sideBarContainerId: this.viewsService.getVisibleViewContainer(ViewContainerLocation.Sidebar)?.id,
+			auxiliaryBarVisible: this.layoutService.isVisible(Parts.AUXILIARYBAR_PART),
+			auxiliaryBarContainerId: this.viewsService.getVisibleViewContainer(ViewContainerLocation.AuxiliaryBar)?.id,
+			panelVisible: this.layoutService.isVisible(Parts.PANEL_PART),
+			editorVisible: this.layoutService.isVisible(Parts.EDITOR_PART, mainWindow),
+		};
+	}
+
+	private readLayoutSnapshot(): IAiHubLayoutSnapshot | undefined {
+		const raw = this.storageService.get(AI_HUB_LAYOUT_STORAGE_KEY, StorageScope.PROFILE);
+		if (!raw) {
+			return undefined;
+		}
+
+		try {
+			return JSON.parse(raw) as IAiHubLayoutSnapshot;
+		} catch {
+			return undefined;
+		}
+	}
+
+	private async openFirstAvailableViewContainer(containerIds: readonly string[]): Promise<void> {
+		for (const id of containerIds) {
+			try {
+				const paneComposite = await this.viewsService.openViewContainer(id, true);
+				if (paneComposite) {
+					return;
+				}
+			} catch {
+				// Agent containers can be conditional; try the next known location.
+			}
+		}
+	}
+
+	private async restoreEditLayout(): Promise<void> {
+		this.layoutService.setAuxiliaryBarMaximized(false);
+		const snapshot = this.readLayoutSnapshot();
+		if (!snapshot) {
+			this.layoutService.setPartHidden(false, Parts.ACTIVITYBAR_PART);
+			this.layoutService.setPartHidden(false, Parts.EDITOR_PART);
+			this.layoutService.setPartHidden(true, Parts.PANEL_PART);
+			return;
+		}
+
+		this.layoutService.setPartHidden(!snapshot.activityBarVisible, Parts.ACTIVITYBAR_PART);
+		this.layoutService.setPartHidden(!snapshot.editorVisible, Parts.EDITOR_PART);
+		this.layoutService.setPartHidden(!snapshot.panelVisible, Parts.PANEL_PART);
+
+		if (snapshot.sideBarVisible) {
+			this.layoutService.setPartHidden(false, Parts.SIDEBAR_PART);
+			if (snapshot.sideBarContainerId) {
+				await this.viewsService.openViewContainer(snapshot.sideBarContainerId, false);
+			}
+		} else {
+			this.layoutService.setPartHidden(true, Parts.SIDEBAR_PART);
+		}
+
+		if (snapshot.auxiliaryBarVisible) {
+			this.layoutService.setPartHidden(false, Parts.AUXILIARYBAR_PART);
+			if (snapshot.auxiliaryBarContainerId) {
+				await this.viewsService.openViewContainer(snapshot.auxiliaryBarContainerId, false);
+			}
+		} else {
+			this.layoutService.setPartHidden(true, Parts.AUXILIARYBAR_PART);
+		}
+
+		this.storageService.remove(AI_HUB_LAYOUT_STORAGE_KEY, StorageScope.PROFILE);
+	}
+
+	private async applyAgentLayout(mode: AiHubMode): Promise<void> {
+		this.layoutService.setAuxiliaryBarMaximized(false);
+		this.layoutService.setPartHidden(false, Parts.SIDEBAR_PART);
+		this.layoutService.setPartHidden(false, Parts.AUXILIARYBAR_PART);
+		this.hideForbiddenParts();
+
+		try {
+			await this.commandService.executeCommand(mode === 'claudeAgent' ? 'claude-vscode.sidebar.open' : 'chatgpt.openSidebar');
+		} catch (error) {
+			this.logService.warn('[aiHub] failed to open agent sidebar via extension command', error);
+		}
+
+		await this.openFirstAvailableViewContainer(this.getAgentContainerIds(mode));
+		if (!this.arrangeAgentContainer(mode)) {
+			this.layoutService.setPartHidden(false, Parts.AUXILIARYBAR_PART);
+			this.layoutService.setPartHidden(true, Parts.SIDEBAR_PART);
+			this.layoutService.setAuxiliaryBarMaximized(true);
+		}
+		this.hideForbiddenParts();
+		this.layoutService.layout();
+	}
+
+	private async applyModeLayout(mode: AiHubMode, previousMode: AiHubMode): Promise<void> {
+		this.applyingLayout = true;
+		try {
+			if (mode === 'edit') {
+				if (previousMode !== 'edit' || this.readLayoutSnapshot()) {
+					await this.restoreEditLayout();
+				}
+				return;
+			}
+
+			await this.applyAgentLayout(mode);
+		} finally {
+			this.applyingLayout = false;
+		}
+	}
+
+	private arrangeAgentContainer(mode: AiHubMode): boolean {
+		const agentContainerIds = new Set(this.getAgentContainerIds(mode));
+		const sideBarContainerId = this.viewsService.getVisibleViewContainer(ViewContainerLocation.Sidebar)?.id;
+		const auxiliaryBarContainerId = this.viewsService.getVisibleViewContainer(ViewContainerLocation.AuxiliaryBar)?.id;
+
+		if (sideBarContainerId && agentContainerIds.has(sideBarContainerId)) {
+			this.layoutService.setAuxiliaryBarMaximized(false);
+			this.layoutService.setPartHidden(false, Parts.SIDEBAR_PART);
+			this.layoutService.setPartHidden(true, Parts.AUXILIARYBAR_PART);
+			return true;
+		}
+
+		if (auxiliaryBarContainerId && agentContainerIds.has(auxiliaryBarContainerId)) {
+			this.layoutService.setPartHidden(false, Parts.AUXILIARYBAR_PART);
+			this.layoutService.setPartHidden(true, Parts.SIDEBAR_PART);
+			this.layoutService.setAuxiliaryBarMaximized(true);
+			return true;
+		}
+
+		return false;
+	}
+
+	private async enforceAgentLayout(): Promise<void> {
+		if (this.currentMode === 'edit') {
+			return;
+		}
+		if (this.applyingLayout) {
+			this.enforcementScheduler.schedule(16);
+			return;
+		}
+
+		this.applyingLayout = true;
+		try {
+			const mode = this.currentMode;
+			if (!this.arrangeAgentContainer(mode)) {
+				await this.applyAgentLayout(mode);
+			}
+			if (this.currentMode === mode) {
+				this.hideForbiddenParts();
+				this.layoutService.layout();
+			}
+		} finally {
+			this.applyingLayout = false;
+		}
+	}
+
+	private isForbiddenPart(partId: string): boolean {
+		return partId === Parts.ACTIVITYBAR_PART || partId === Parts.EDITOR_PART || partId === Parts.PANEL_PART;
+	}
+
+	private hideForbiddenParts(): void {
+		this.layoutService.setPartHidden(true, Parts.ACTIVITYBAR_PART);
+		this.layoutService.setPartHidden(true, Parts.PANEL_PART);
+		this.layoutService.setPartHidden(true, Parts.EDITOR_PART);
+	}
+}
