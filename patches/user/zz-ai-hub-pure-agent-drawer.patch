+
+type AiHubDrawerKind = 'settings' | 'gateway';
+
+const DRAWER_TRANSITION_MS = 180;
+
+function parseAiHubMode(value: unknown): AiHubMode {
+	return value === 'claudeAgent' || value === 'codexAgent' ? value : 'edit';
+}
+
+export class AiHubDrawerService extends Disposable implements IAiHubDrawerService {
+
+	declare readonly _serviceBrand: undefined;
+
+	private readonly container: HTMLElement;
+	private readonly titleElement: HTMLElement;
+	private readonly settingsHost: HTMLElement;
+	private readonly gatewayHost: HTMLElement;
+	private readonly settingsWebview: IOverlayWebview;
+	private gatewayModel: IBrowserViewModel | undefined;
+	private activeDrawer: AiHubDrawerKind | undefined;
+	private operationId = 0;
+
+	constructor(
+		@IWebviewService webviewService: IWebviewService,
+		@IBrowserViewWorkbenchService private readonly browserViewService: IBrowserViewWorkbenchService,
+		@IProductService private readonly productService: IProductService,
+		@IAiConfigService private readonly aiConfigService: IAiConfigService,
+		@IAiHubModeController private readonly modeController: IAiHubModeController,
+		@ICommandService private readonly commandService: ICommandService,
+		@INotificationService private readonly notificationService: INotificationService,
+		@ILogService private readonly logService: ILogService,
+		@IWorkbenchLayoutService private readonly layoutService: IWorkbenchLayoutService,
+	) {
+		super();
+
+		this.container = $('.ai-hub-drawer');
+		this.container.setAttribute('role', 'dialog');
+		this.container.setAttribute('aria-modal', 'false');
+		this.container.setAttribute('aria-hidden', 'true');
+
+		const header = $('.ai-hub-drawer-header');
+		this.titleElement = $('.ai-hub-drawer-title');
+		header.appendChild(this.titleElement);
+
+		const closeButton = $('button.ai-hub-drawer-close.codicon.codicon-close') as HTMLButtonElement;
+		closeButton.type = 'button';
+		closeButton.title = localize('aiHub.drawer.close', "Close");
+		closeButton.setAttribute('aria-label', localize('aiHub.drawer.close', "Close"));
+		header.appendChild(closeButton);
+		this.container.appendChild(header);
+
+		const body = $('.ai-hub-drawer-body');
+		this.settingsHost = $('.ai-hub-drawer-content.ai-hub-drawer-settings');
+		this.gatewayHost = $('.ai-hub-drawer-content.ai-hub-drawer-gateway');
+		body.append(this.settingsHost, this.gatewayHost);
+		this.container.appendChild(body);
+
+		const workbenchContainer = this.layoutService.getContainer(mainWindow);
+		workbenchContainer.appendChild(this.container);
+		this._register(toDisposable(() => this.container.remove()));
+
+		this.settingsWebview = this._register(webviewService.createWebviewOverlay({
+			providedViewType: 'aiHub.settings.drawer',
+			title: localize('aiHub.title', "AI Settings"),
+			options: {
+				purpose: WebviewContentPurpose.WebviewView,
+				retainContextWhenHidden: true,
+			},
+			contentOptions: { allowScripts: true },
+			extension: undefined,
+		}));
+
+		this._register(this.settingsWebview.onMessage(({ message }) => void this.handleSettingsMessage(message)));
+		this._register(addDisposableListener(closeButton, EventType.CLICK, () => void this.close()));
+		this._register(addDisposableListener(mainWindow, EventType.KEY_DOWN, event => {
+			if (event.key === 'Escape' && this.activeDrawer) {
+				void this.close();
+			}
+		}, true));
+		this._register(this.layoutService.onDidLayoutMainContainer(() => this.layoutDrawer()));
+
+		const resizeObserver = new mainWindow.ResizeObserver(() => {
+			this.layoutDrawer();
+			if (this.activeDrawer === 'gateway') {
+				void this.layoutGateway();
+			}
+		});
+		resizeObserver.observe(this.container);
+		this._register(toDisposable(() => resizeObserver.disconnect()));
+
+		this.layoutDrawer();
+	}
+
+	async toggleSettings(): Promise<void> {
+		if (this.activeDrawer === 'settings') {
+			await this.close();
+			return;
+		}
+
+		await this.refreshSettings();
+		await this.show('settings');
+	}
+
+	async toggleGateway(): Promise<void> {
+		if (this.activeDrawer === 'gateway') {
+			await this.close();
+			return;
+		}
+
+		if (!this.productService.aiGatewayUrl) {
+			this.notificationService.warn(localize('aiHub.gatewayUrlMissing', "AI Gateway URL is not configured."));
+			return;
+		}
+
+		await this.show('gateway');
+	}
+
+	async close(): Promise<void> {
+		if (!this.activeDrawer) {
+			return;
+		}
+
+		const operationId = ++this.operationId;
+		await this.hideActiveContent();
+		this.activeDrawer = undefined;
+		this.container.classList.remove('ai-hub-drawer-open');
+		this.container.setAttribute('aria-hidden', 'true');
+
+		await this.waitForTransition();
+		if (operationId === this.operationId && !this.activeDrawer) {
+			this.container.classList.remove('ai-hub-drawer-visible');
+		}
+	}
+
+	private async show(kind: AiHubDrawerKind): Promise<void> {
+		const operationId = ++this.operationId;
+		const wasOpen = !!this.activeDrawer;
+		await this.hideActiveContent();
+		if (operationId !== this.operationId) {
+			return;
+		}
+
+		this.activeDrawer = kind;
+		this.titleElement.textContent = kind === 'settings'
+			? localize('aiHub.title', "AI Settings")
+			: localize('aiHub.gatewayTitle', "AI Gateway");
+		this.settingsHost.classList.toggle('active', kind === 'settings');
+		this.gatewayHost.classList.toggle('active', kind === 'gateway');
+		this.container.classList.add('ai-hub-drawer-visible');
+		this.container.setAttribute('aria-hidden', 'false');
+		this.layoutDrawer();
+
+		if (!wasOpen) {
+			this.container.getBoundingClientRect();
+			this.container.classList.add('ai-hub-drawer-open');
+			await this.waitForTransition();
+		}
+		if (operationId !== this.operationId || this.activeDrawer !== kind) {
+			return;
+		}
+
+		if (kind === 'settings') {
+			this.settingsWebview.claim(this, mainWindow, undefined);
+			this.settingsWebview.setAnchorElement(this.settingsHost, this.container);
+			return;
+		}
+
+		await this.showGateway(operationId);
+	}
+
+	private async hideActiveContent(): Promise<void> {
+		if (this.activeDrawer === 'settings') {
+			this.settingsWebview.release(this);
+		}
+		if (this.activeDrawer === 'gateway' && this.gatewayModel) {
+			await this.gatewayModel.setVisible(false).catch(error => this.logService.warn('[aiHub] failed to hide gateway drawer', error));
+		}
+	}
+
+	private async showGateway(operationId: number): Promise<void> {
+		const gatewayUrl = this.productService.aiGatewayUrl ?? '';
+		const input = this.browserViewService.getOrCreateLazy('ai-gateway-drawer', {
+			url: gatewayUrl,
+			title: localize('aiHub.gatewayTitle', "AI Gateway"),
+		});
+		if (input.url !== gatewayUrl) {
+			input.navigate(gatewayUrl);
+		}
+
+		const model = await input.resolve();
+		if (operationId !== this.operationId || this.activeDrawer !== 'gateway') {
+			await model.setVisible(false);
+			return;
+		}
+
+		this.gatewayModel = model;
+		await this.layoutGateway();
+		await model.setVisible(true);
+		await this.layoutGateway();
+	}
+
+	private async layoutGateway(): Promise<void> {
+		if (!this.gatewayModel || this.activeDrawer !== 'gateway') {
+			return;
+		}
+
+		const rect = this.gatewayHost.getBoundingClientRect();
+		if (rect.width < 1 || rect.height < 1) {
+			return;
+		}
+
+		await this.gatewayModel.layout({
+			windowId: mainWindow.vscodeWindowId,
+			x: rect.left,
+			y: rect.top,
+			width: rect.width,
+			height: rect.height,
+			zoomFactor: getZoomFactor(mainWindow),
+			cornerRadius: 0,
+		});
+	}
+
+	private layoutDrawer(): void {
+		const workbenchRect = this.layoutService.getContainer(mainWindow).getBoundingClientRect();
+		const titleBarRect = this.layoutService.getContainer(mainWindow, Parts.TITLEBAR_PART)?.getBoundingClientRect();
+		const top = titleBarRect ? Math.max(0, titleBarRect.bottom - workbenchRect.top) : 0;
+		this.container.style.top = `${top}px`;
+	}
+
+	private waitForTransition(): Promise<void> {
+		return new Promise(resolve => mainWindow.setTimeout(resolve, DRAWER_TRANSITION_MS));
+	}
+
+	private async refreshSettings(): Promise<void> {
+		const state = await this.aiConfigService.getState();
+		this.settingsWebview.setHtml(buildAiHubHtml(state));
+	}
+
+	private async handleSettingsMessage(message: any): Promise<void> {
+		try {
+			switch (message?.type) {
+				case 'save': {
+					const settings = { baseUrl: message.baseUrl ?? '', apiKey: message.apiKey ?? '' };
+					if (message.provider === 'claude' && settings.apiKey) {
+						await this.aiConfigService.saveClaudeSettings(settings);
+					} else if (message.provider === 'codex' && settings.apiKey) {
+						await this.aiConfigService.saveCodexSettings(settings);
+					}
+					await this.refreshSettings();
+					break;
+				}
+				case 'toggleExtension': {
+					const id = message.id === 'claude' ? CLAUDE_EXTENSION_ID : CODEX_EXTENSION_ID;
+					const enabled = !!message.enabled;
+					await this.aiConfigService.setExtensionEnabled(id, enabled);
+					await this.refreshSettings();
+					const agentName = message.id === 'claude' ? 'Claude Code' : 'Codex';
+					this.notificationService.info(enabled
+						? localize('aiHub.agentConnected', "{0} 已接入", agentName)
+						: localize('aiHub.agentDisconnected', "{0} 已断开接入", agentName));
+					break;
+				}
+				case 'setMode': {
+					const mode = parseAiHubMode(message.mode);
+					await this.modeController.setMode(mode);
+					await this.refreshSettings();
+					this.notificationService.info(mode === 'edit'
+						? localize('aiHub.editModeEnabled', "已切换到编辑模式")
+						: localize('aiHub.agentModeEnabled', "已切换到 {0}", mode === 'claudeAgent' ? 'Claude Agent' : 'Codex Agent'));
+					break;
+				}
+				case 'openGateway': {
+					await this.show('gateway');
+					break;
+				}
+				case 'openEditorSettings': {
+					if (this.modeController.mode !== 'edit') {
+						this.notificationService.info(localize('aiHub.editorSettingsRequireEditMode', "请先切换到编辑模式再打开编辑器设置。"));
+						break;
+					}
+					await this.close();
+					await this.commandService.executeCommand('workbench.action.openSettings');
+					break;
+				}
+			}
+		} catch (error) {
+			this.logService.error('[aiHub] failed to handle drawer message', error);
+		}
+	}
+
+	override dispose(): void {
+		void this.gatewayModel?.setVisible(false);
+		this.settingsWebview.release(this);
+		super.dispose();
+	}
+}
