+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+.ai-hub-drawer {
+	position: absolute;
+	right: 0;
+	bottom: 0;
+	z-index: 200;
+	display: flex;
+	width: min(620px, calc(100% - 32px));
+	min-width: min(360px, 100%);
+	flex-direction: column;
+	color: var(--vscode-foreground);
+	background: var(--vscode-sideBar-background);
+	border-left: 1px solid var(--vscode-sideBar-border, var(--vscode-widget-border));
+	box-shadow: -10px 0 28px rgba(0, 0, 0, 0.28);
+	transform: translateX(100%);
+	visibility: hidden;
+	pointer-events: none;
+	transition: transform 180ms ease, visibility 0s linear 180ms;
+}
+
+.ai-hub-drawer.ai-hub-drawer-visible {
+	visibility: visible;
+}
+
+.ai-hub-drawer.ai-hub-drawer-open {
+	transform: translateX(0);
+	pointer-events: auto;
+	transition: transform 180ms ease;
+}
+
+.ai-hub-drawer-header {
+	display: flex;
+	min-height: 42px;
+	align-items: center;
+	justify-content: space-between;
+	box-sizing: border-box;
+	padding: 0 8px 0 16px;
+	background: var(--vscode-sideBarSectionHeader-background, var(--vscode-sideBar-background));
+	border-bottom: 1px solid var(--vscode-sideBar-border, var(--vscode-widget-border));
+}
+
+.ai-hub-drawer-title {
+	overflow: hidden;
+	font-size: 13px;
+	font-weight: 600;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.ai-hub-drawer-close {
+	width: 28px;
+	height: 28px;
+	padding: 0;
+	color: var(--vscode-icon-foreground);
+	background: transparent;
+	border: 0;
+	cursor: pointer;
+}
+
+.ai-hub-drawer-close:hover {
+	background: var(--vscode-toolbar-hoverBackground);
+}
+
+.ai-hub-drawer-close:focus-visible {
+	outline: 1px solid var(--vscode-focusBorder);
+	outline-offset: -1px;
+}
+
+.ai-hub-drawer-body,
+.ai-hub-drawer-content {
+	position: relative;
+	min-width: 0;
+	min-height: 0;
+	flex: 1;
+}
+
+.ai-hub-drawer-content {
+	display: none;
+}
+
+.ai-hub-drawer-content.active {
+	display: block;
+}
+
+@media (max-width: 520px) {
+	.ai-hub-drawer {
+		width: 100%;
+		min-width: 0;
+	}
+}
+
+@media (prefers-reduced-motion: reduce) {
+	.ai-hub-drawer,
+	.ai-hub-drawer.ai-hub-drawer-open {
+		transition-duration: 0s;
+	}
+}
