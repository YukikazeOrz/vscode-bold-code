+.bold-frontend__topbar-actions {
+	display: flex;
+	flex: 0 0 auto;
+	align-items: center;
+	gap: 6px;
+}
+
+.bold-frontend__search-button,
+.bold-frontend__topbar-button {
+	height: 32px;
+	box-sizing: border-box;
+	align-items: center;
+	gap: 7px;
+	padding: 0 10px;
+	border: 1px solid color-mix(in srgb, var(--vscode-foreground) 8%, transparent);
+	border-radius: 9px;
+	background: color-mix(in srgb, var(--vscode-input-background) 88%, transparent);
+	color: color-mix(in srgb, var(--vscode-foreground) 65%, transparent);
+}
+
+.bold-frontend__search-button:hover,
+.bold-frontend__topbar-button:hover,
+.bold-frontend__search-button:focus-visible,
+.bold-frontend__topbar-button:focus-visible {
+	outline: 0;
+	border-color: color-mix(in srgb, var(--vscode-focusBorder) 42%, transparent);
