+}
+
+.bold-frontend__search-button {
+	min-width: 180px;
+}
+
+.bold-frontend__search-button .bold-frontend__button-label,
+.bold-frontend__topbar-button .bold-frontend__button-label {
+	font-size: 10px;
+}
+
+.bold-frontend__statusbar {
+	position: absolute;
+	right: 0;
+	bottom: 0;
+	left: var(--bold-shell-left);
+	display: flex;
+	height: var(--bold-statusbar-height);
+	box-sizing: border-box;
+	align-items: center;
+	padding: 0 14px;
+	color: color-mix(in srgb, var(--vscode-foreground) 47%, transparent);
+	font-size: 10px;
+}
+
+.bold-frontend__status-item.is-connected {
+	color: color-mix(in srgb, #4dc97b 78%, var(--vscode-foreground));
+}
+
+.bold-frontend__status-item.is-error {
+	color: var(--vscode-errorForeground);
+}
+
+.bold-frontend__status-item--right {
+	margin-left: auto;
+}
+
+@media (max-width: 900px) {
+	body.bold-independent-frontend {
+		--bold-explorer-width: 220px;
+	}
+
+	.bold-frontend__search-button {
+		min-width: 34px;
+	}
+
+	.bold-frontend__search-button .bold-frontend__button-label,
+	.bold-frontend__topbar-button .bold-frontend__button-label {
+		display: none;
+	}
+}
+
+@media (max-width: 1000px) {
+	body.ai-hub-edit-chat-mode.bold-independent-frontend {
+		--bold-explorer-width: 0px;
+		--bold-chat-width: min(360px, 42vw);
+	}
+
+	body.ai-hub-edit-chat-mode .bold-frontend__explorer {
+		display: none;
+	}
+}
+
+@media (max-width: 680px) {
+	body.bold-independent-frontend {
+		--bold-explorer-width: 0px;
+	}
+
+	.bold-frontend__explorer {
+		display: none;
+	}
+}
+
+@media (prefers-reduced-motion: reduce) {
+	.bold-frontend *,
+	.bold-frontend *::before,
+	.bold-frontend *::after {
+		scroll-behavior: auto !important;
+		transition-duration: 0s !important;
+	}
+}
