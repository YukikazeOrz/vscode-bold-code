+		element.remove();
+	}
+
+	const screen = document.createElement('div');
+	screen.className = 'bold-frontend-bootstrap';
+	screen.setAttribute('role', 'progressbar');
+	screen.setAttribute('aria-label', 'Bold Code 正在启动');
+
