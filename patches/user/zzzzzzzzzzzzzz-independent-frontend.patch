+	border: 0;
+	border-radius: 7px;
+	background: transparent;
+	color: color-mix(in srgb, var(--vscode-foreground) 76%, transparent);
+	cursor: default;
+	text-align: left;
+}
+
+.bold-frontend__tree-row:hover,
+.bold-frontend__tree-row:focus-visible {
+	outline: 0;
+	background: color-mix(in srgb, var(--vscode-foreground) 7%, transparent);
+	color: var(--vscode-foreground);
+}
+
+.bold-frontend__tree-branch.is-root > .bold-frontend__tree-row {
+	height: 30px;
+	font-weight: 650;
+}
+
+.bold-frontend__tree-chevron {
+	display: grid;
+	width: 14px;
+	height: 18px;
+	flex: 0 0 14px;
+	place-items: center;
+	color: color-mix(in srgb, var(--vscode-foreground) 45%, transparent);
+	font-size: 17px;
+	transition: transform 120ms ease;
+}
+
+.bold-frontend__tree-branch.is-expanded > .bold-frontend__tree-row > .bold-frontend__tree-chevron {
+	transform: rotate(90deg);
+}
+
+.bold-frontend__file-icon {
+	width: 17px;
+	flex: 0 0 17px;
+	color: color-mix(in srgb, var(--vscode-focusBorder) 74%, var(--vscode-foreground));
+	font-size: 11px;
+	line-height: 1;
+	text-align: center;
+}
+
+.bold-frontend__file-icon.is-folder {
+	color: color-mix(in srgb, #d9a441 75%, var(--vscode-foreground));
+	font-size: 8px;
+}
+
+.bold-frontend__tree-name {
+	overflow: hidden;
+	min-width: 0;
+	font-size: 12px;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.bold-frontend__tree-children:empty {
+	display: none;
+}
+
+.bold-frontend__tree-error {
+	padding: 5px 10px 6px 32px;
+	color: var(--vscode-errorForeground);
+	font-size: 11px;
+}
+
+.bold-frontend__empty-state {
+	display: flex;
+	flex-direction: column;
+	align-items: flex-start;
+	gap: 7px;
