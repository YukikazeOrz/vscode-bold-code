+	border-radius: 8px;
+	background: color-mix(in srgb, var(--vscode-focusBorder) 10%, transparent);
+	color: var(--vscode-foreground);
+}
+
+.bold-frontend__empty-action .bold-frontend__button-label {
+	font-size: 11px;
+}
+
+.bold-frontend__topbar {
