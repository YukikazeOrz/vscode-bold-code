+}
+
+.bold-frontend__tab-close:hover {
+	background: color-mix(in srgb, var(--vscode-foreground) 10%, transparent);
+	opacity: 1;
+}
+
+.bold-frontend__empty-tab {
+	padding-left: 8px;
+	color: color-mix(in srgb, var(--vscode-foreground) 35%, transparent);
+	font-size: 11px;
+}
