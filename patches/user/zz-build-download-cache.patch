+const downloadCacheRoot = process.env['VSCODE_DOWNLOAD_CACHE'];
+const refreshDownloadCache = process.env['VSCODE_DOWNLOAD_CACHE_REFRESH'] === '1';
+
+function checksum(contents: Buffer): string {
+	return crypto.createHash('sha256').update(contents).digest('hex');
+}
+
+function getDownloadCachePath(url: string): string | undefined {
+	if (!downloadCacheRoot) {
+		return undefined;
+	}
+
+	return path.join(downloadCacheRoot, checksum(Buffer.from(url)));
+}
+
+function readCachedDownload(url: string, expectedChecksum?: string): Buffer | undefined {
+	const cachePath = getDownloadCachePath(url);
+	if (!cachePath || refreshDownloadCache || !fs.existsSync(cachePath)) {
+		return undefined;
+	}
+
+	const contents = fs.readFileSync(cachePath);
+	if (expectedChecksum && checksum(contents) !== expectedChecksum) {
+		fs.rmSync(cachePath, { force: true });
+		return undefined;
+	}
+
+	log(`Using cached download: ${ansiColors.cyan(url)}`);
+	return contents;
+}
+
+function writeCachedDownload(url: string, contents: Buffer): void {
+	const cachePath = getDownloadCachePath(url);
+	if (!cachePath) {
+		return;
+	}
+
+	fs.mkdirSync(path.dirname(cachePath), { recursive: true });
+	const tempPath = `${cachePath}.${process.pid}.${crypto.randomBytes(6).toString('hex')}.tmp`;
+	try {
+		fs.writeFileSync(tempPath, contents);
+		fs.rmSync(cachePath, { force: true });
+		fs.renameSync(tempPath, cachePath);
+	} finally {
+		fs.rmSync(tempPath, { force: true });
+	}
+}
