+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { localize, localize2 } from '../../../../nls.js';
+import { Registry } from '../../../../platform/registry/common/platform.js';
+import { Codicon } from '../../../../base/common/codicons.js';
+import { registerIcon } from '../../../../platform/theme/common/iconRegistry.js';
+import { SyncDescriptor } from '../../../../platform/instantiation/common/descriptors.js';
+import { InstantiationType, registerSingleton } from '../../../../platform/instantiation/common/extensions.js';
+import { Extensions as WorkbenchExtensions, IWorkbenchContributionsRegistry } from '../../../common/contributions.js';
+import { IViewContainersRegistry, IViewsRegistry, Extensions as ViewExtensions, ViewContainerLocation, ViewContainer } from '../../../common/views.js';
+import { ViewPaneContainer } from '../../../browser/parts/views/viewPaneContainer.js';
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { LifecyclePhase } from '../../../services/lifecycle/common/lifecycle.js';
+import { IStorageService, StorageScope, StorageTarget } from '../../../../platform/storage/common/storage.js';
+import { ACTIVE_GROUP } from '../../../services/editor/common/editorService.js';
+import { ICommandService, CommandsRegistry } from '../../../../platform/commands/common/commands.js';
+import { IProductService } from '../../../../platform/product/common/productService.js';
+import { ILogService } from '../../../../platform/log/common/log.js';
+import { IWebviewWorkbenchService } from '../../webviewPanel/browser/webviewWorkbenchService.js';
+import { WebviewInput } from '../../webviewPanel/browser/webviewEditorInput.js';
+import { IAiExtensionHostEnvironmentContributor } from '../../../../platform/environment/common/aiExtensionHostEnvironment.js';
+import { AiConfigService } from './aiConfigService.js';
+import { AiHubViewPane } from './aiHubViewPane.js';
+import { buildAiHubHtml } from './aiHubHtml.js';
+import { openAiGatewayWebview } from './aiGatewayWebview.js';
+import { AI_HUB_OPEN_COMMAND_ID, CLAUDE_EXTENSION_ID, CODEX_EXTENSION_ID, IAiConfigService } from './aiHubTypes.js';
+
+const AI_HUB_VIEW_CONTAINER_ID = 'workbench.view.aiHub';
+const AI_HUB_VIEW_ID = 'workbench.view.aiHub.launcher';
+const AI_HUB_WEBVIEW_VIEW_TYPE = 'aiHub.settings';
+const AI_HUB_FIRST_RUN_STORAGE_KEY = 'aiHub.firstRunHandled';
+
+registerSingleton(IAiConfigService, AiConfigService, InstantiationType.Delayed);
+registerSingleton(IAiExtensionHostEnvironmentContributor, AiConfigService, InstantiationType.Delayed);
+
+const aiHubIcon = registerIcon('ai-hub-view-icon', Codicon.chatSparkle, localize('aiHubViewIcon', "AI settings icon in the activity bar."));
+
+const viewContainer: ViewContainer = Registry.as<IViewContainersRegistry>(ViewExtensions.ViewContainersRegistry).registerViewContainer(
+	{
+		id: AI_HUB_VIEW_CONTAINER_ID,
+		title: localize2('aiHub.viewContainer', "AI Settings"),
+		icon: aiHubIcon,
+		ctorDescriptor: new SyncDescriptor(ViewPaneContainer, [AI_HUB_VIEW_CONTAINER_ID, { mergeViewWithContainerWhenSingleView: true }]),
+		order: 100,
+	},
+	ViewContainerLocation.Sidebar,
+	{ doNotRegisterOpenCommand: true },
+);
+
+Registry.as<IViewsRegistry>(ViewExtensions.ViewsRegistry).registerViews([{
+	id: AI_HUB_VIEW_ID,
+	name: localize2('aiHub.view', "AI Settings"),
+	ctorDescriptor: new SyncDescriptor(AiHubViewPane),
+	canToggleVisibility: false,
+	canMoveView: false,
+	containerIcon: aiHubIcon,
+}], viewContainer);
+
+let currentWebview: WebviewInput | undefined;
+
+CommandsRegistry.registerCommand(AI_HUB_OPEN_COMMAND_ID, async (accessor) => {
+	const webviewWorkbenchService = accessor.get(IWebviewWorkbenchService);
+	const aiConfigService = accessor.get(IAiConfigService);
+	const productService = accessor.get(IProductService);
+	const logService = accessor.get(ILogService);
+
+	if (currentWebview && !currentWebview.isDisposed()) {
+		webviewWorkbenchService.revealWebview(currentWebview, ACTIVE_GROUP, false);
+		return;
+	}
+
+	const state = await aiConfigService.getState();
+	const webview = webviewWorkbenchService.openWebview(
+		{
+			title: localize('aiHub.title', "AI Settings"),
+			options: { retainContextWhenHidden: true },
+			contentOptions: { allowScripts: true },
+			extension: undefined,
+		},
+		AI_HUB_WEBVIEW_VIEW_TYPE,
+		localize('aiHub.title', "AI Settings"),
+		undefined,
+		{ preserveFocus: false },
+	);
+	currentWebview = webview;
+	webview.webview.setHtml(buildAiHubHtml(state));
+
+	webview.webview.onMessage(async ({ message }) => {
+		try {
+			switch (message?.type) {
+				case 'save': {
+					const settings = { baseUrl: message.baseUrl ?? '', apiKey: message.apiKey ?? '' };
+					if (message.provider === 'claude' && settings.apiKey) {
+						await aiConfigService.saveClaudeSettings(settings);
+					} else if (message.provider === 'codex' && settings.apiKey) {
+						await aiConfigService.saveCodexSettings(settings);
+					}
+					const refreshed = await aiConfigService.getState();
+					webview.webview.setHtml(buildAiHubHtml(refreshed));
+					break;
+				}
+				case 'toggleExtension': {
+					const id = message.id === 'claude' ? CLAUDE_EXTENSION_ID : CODEX_EXTENSION_ID;
+					await aiConfigService.setExtensionEnabled(id, !!message.enabled);
+					break;
+				}
+				case 'openGateway': {
+					openAiGatewayWebview(webviewWorkbenchService, productService.aiGatewayUrl ?? '');
+					break;
+				}
+			}
+		} catch (err) {
+			logService.error('[aiHub] failed to handle webview message', err);
+		}
+	});
+
+	webview.webview.onDidDispose(() => {
+		if (currentWebview === webview) {
+			currentWebview = undefined;
+		}
+	});
+});
+
+/**
+ * Stands in for a dedicated first-run wizard: on the very first activation after install,
+ * just open the AI Hub itself (its extension-enablement checkboxes already let the user pick
+ * Claude/Codex on/off), instead of building a second, separate picker UI for the same choice.
+ */
+class AiHubFirstRunContribution extends Disposable {
+	static readonly ID = 'workbench.contrib.aiHubFirstRun';
+
+	constructor(
+		@IStorageService storageService: IStorageService,
+		@ICommandService commandService: ICommandService,
+	) {
+		super();
+		if (!storageService.getBoolean(AI_HUB_FIRST_RUN_STORAGE_KEY, StorageScope.APPLICATION, false)) {
+			storageService.store(AI_HUB_FIRST_RUN_STORAGE_KEY, true, StorageScope.APPLICATION, StorageTarget.MACHINE);
+			void commandService.executeCommand(AI_HUB_OPEN_COMMAND_ID);
+		}
+	}
+}
+
+Registry.as<IWorkbenchContributionsRegistry>(WorkbenchExtensions.Workbench).registerWorkbenchContribution(AiHubFirstRunContribution, LifecyclePhase.Restored);
