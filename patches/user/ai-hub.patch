+/*---------------------------------------------------------------------------------------------
+ *  Copyright (c) Microsoft Corporation. All rights reserved.
+ *  Licensed under the MIT License. See License.txt in the project root for license information.
+ *--------------------------------------------------------------------------------------------*/
+
+import { localize } from '../../../../nls.js';
+import { IWebviewWorkbenchService } from '../../webviewPanel/browser/webviewWorkbenchService.js';
+
+export const AI_GATEWAY_WEBVIEW_VIEW_TYPE = 'aiHub.gateway';
+
+/**
+ * Opens the AI gateway login/key-management page as an editor-area tab, the same way the
+ * built-in Simple Browser extension opens external URLs: a cross-origin <iframe> inside our
+ * own sandboxed webview page. That sandboxing is exactly why this can only show the page, not
+ * script it — a same-origin-policy boundary Electron's <webview> tag can bypass but the
+ * standard VS Code webview abstraction deliberately does not expose (see aiHub.contribution.ts
+ * for why importing a key from here still requires manual copy/paste for now).
+ */
+export function openAiGatewayWebview(webviewWorkbenchService: IWebviewWorkbenchService, gatewayUrl: string): void {
+	const webview = webviewWorkbenchService.openWebview(
+		{
+			title: localize('aiHub.gateway.title', "AI Gateway"),
+			options: { retainContextWhenHidden: true },
+			contentOptions: { allowScripts: true },
+			extension: undefined,
+		},
+		AI_GATEWAY_WEBVIEW_VIEW_TYPE,
+		localize('aiHub.gateway.title', "AI Gateway"),
+		undefined,
+		{ preserveFocus: false },
+	);
+
+	webview.webview.setHtml(`<!DOCTYPE html>
+<html>
+<head><meta charset="UTF-8"><style>html,body,iframe{margin:0;padding:0;width:100%;height:100%;border:none;}</style></head>
+<body><iframe src="${gatewayUrl}" sandbox="allow-scripts allow-forms allow-same-origin allow-popups"></iframe></body>
+</html>`);
+}
